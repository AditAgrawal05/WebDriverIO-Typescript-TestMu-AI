{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "types": ["node", "mocha", "@wdio/globals/types"]
  },
  "include": ["src/**/*.ts", "wdio.conf.ts"],
  "exclude": ["node_modules", "dist"]
}
